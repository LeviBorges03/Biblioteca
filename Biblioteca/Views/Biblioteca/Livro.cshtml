@{
    ViewData["Title"] = "Detalhes do Livro";
}

@section Styles {
    <link rel="stylesheet" href="~/css/biblioteca.css" />
    <style>
        /* Estilos adicionais para a página do Livro mantendo o padrão biblioteca.css */
        .biblioteca-header-local {
            margin-bottom: 30px;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }

        .back-link {
            text-decoration: none;
            color: var(--accent);
            font-size: 1rem;
            margin-bottom: 10px;
            font-weight: 600;
            transition: color 0.2s;
        }

        .back-link:hover {
            color: var(--primary);
        }

        .biblioteca-header-local h2 {
            margin: 0;
            border-bottom: 3px solid var(--accent);
            padding-bottom: 10px;
            color: var(--primary);
            font-weight: 700;
            display: inline-block;
        }

        /* Hero Section no formato original */
        .livro-hero {
            display: grid;
            grid-template-columns: 300px 1fr;
            gap: 40px;
            background: var(--white);
            padding: 30px;
            border-radius: 12px;
            box-shadow: var(--shadow);
            margin-bottom: 30px;
        }

        .livro-capa-detalhe {
            height: 420px;
            border-radius: 10px;
            position: relative;
            display: flex;
            align-items: flex-end;
            padding: 15px;
            box-shadow: var(--shadow);
            overflow: hidden;
        }

        .livro-header-info {
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .livro-header-info h1 {
            font-size: 2.2rem;
            margin-top: 0;
            color: var(--primary);
        }

        .autor-nome {
            font-size: 1.1rem;
            color: #7f8c8d;
            margin-bottom: 25px;
        }

        .meta-info {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            margin-bottom: 30px;
            padding: 15px 0;
            border-top: 1px solid #eee;
            border-bottom: 1px solid #eee;
        }

        .meta-item {
            font-size: 0.9rem;
            color: var(--primary);
        }

        /* Autor Estilo */
        .autor-card {
            display: flex;
            gap: 15px;
            margin-top: 20px;
            text-decoration: none;
            color: inherit;
            cursor: pointer;
        }

        .autor-foto-placeholder {
            width: 80px;
            height: 80px;
            background: var(--bg-light);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            border: 2px solid #eee;
            font-size: 2rem;
        }

        .autor-bio h4 {
            margin: 0 0 5px 0;
            font-size: 1rem;
            color: var(--primary);
        }

        .autor-bio p {
            font-size: 0.85rem;
            margin: 0;
            color: #7f8c8d;
        }

        /* Responsividade */
        @@media (max-width: 768px) {
            .livro-hero { grid-template-columns: 1fr; text-align: center; }
            .livro-capa-detalhe { height: 350px; width: 250px; margin: 0 auto; }
            .meta-info { justify-content: center; }
            .autor-card { flex-direction: column; align-items: center; text-align: center; }
        }
    </style>
}

<div class="page-wrapper">
    <header class="biblioteca-header-local">
        <!-- Rota de volta para o Catálogo -->
        <a href="@Url.Action("Index", "Biblioteca")" class="back-link">
            ← Voltar ao Catálogo
        </a>
        <h2>Detalhes da Obra</h2>
    </header>

    <main class="livro-detalhe-container">
        <section class="livro-hero">
            <!-- Capa do Livro no padrão Index -->
            <div class="livro-capa-detalhe" id="livroCapaContainer">
                <span class="genero-tag" id="livroGenero"></span>
            </div>

            <div class="livro-header-info">
                <h1 id="livroTitulo">Título Carregando...</h1>
                <p class="autor-nome">Por <strong id="livroAutor">Autor Carregando...</strong></p>
                
                <div class="meta-info">
                    <span class="meta-item"><strong>Publicação:</strong> <span id="livroAno">...</span></span>
                    <span class="meta-item"><strong>Páginas:</strong> <span id="livroPaginas">...</span></span>
                    <span class="meta-item"><strong>Idioma:</strong> Português</span>
                </div>

                <!-- Botão expand-btn padrão (fundo branco, borda azul, hover azul sólido transladado -2px) -->
                <div>
                    <button class="expand-btn">Adicionar aos Favoritos</button>
                </div>
            </div>
        </section>

        <!-- Reuso da div.info-secao da biblioteca.css -->
        <section class="info-secao">
            <div class="info-box">
                <h3>Sinopse</h3>
                <p id="livroSinopse">Carregando sinopse dinâmica da obra baseada na sua seleção... Em breve, mais informações sobre este clássico estarão disponíveis.</p>
                <p>Esta obra destaca-se pela narrativa envolvente e pela profundidade psicológica dos personagens, mantendo seu status como um dos maiores clássicos da literatura.</p>
            </div>

            <div class="info-box">
                <h3>Sobre o Autor</h3>
                <!-- Clicar no autor dentro da página do livro redirecionará para a view Autor -->
                <a href="#" class="autor-card" id="linkParaAutor" onclick="abrirAutorDaObra(event)">
                    <div class="autor-foto-placeholder">
                        <i class="icon">👤</i>
                    </div>
                    <div class="autor-bio">
                        <h4 id="boxNomeAutor">...</h4>
                        <p>Um dos maiores nomes da literatura. Clique para ver o perfil completo e mais publicações.</p>
                    </div>
                </a>
            </div>
        </section>
    </main>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Tenta pegar o livro do LocalStorage
            const data = localStorage.getItem('livroAtual');
            
            if (data) {
                const livro = JSON.parse(data);
                
                // Injeta os dados no DOM genérico
                document.getElementById('livroTitulo').innerText = livro.titulo;
                document.getElementById('livroAutor').innerText = livro.autor;
                document.getElementById('boxNomeAutor').innerText = livro.autor;
                document.getElementById('livroCapaContainer').style.backgroundColor = livro.corCapa;
                document.getElementById('livroGenero').innerText = livro.genero;
                document.getElementById('livroAno').innerText = livro.ano || 'Desconhecido';
                document.getElementById('livroPaginas').innerText = livro.paginas || 'N/A';
                
                // Simular uma sinopse basica baseada no nome
                document.getElementById('livroSinopse').innerText = "Uma extraordinária obra literária do mestre " + livro.autor + ". O livro '" + livro.titulo + "' revolucionou o gênero " + livro.genero + " com sua narrativa única.";
            } else {
                // Fallback caso acesse a página diretamente pela URL sem clicar em um livro
                document.getElementById('livroTitulo').innerText = "Nenhum Livro Selecionado";
                document.getElementById('livroAutor').innerText = "Volte ao Catálogo";
            }
        });

        // Função local para o usuário ir para o Autor estando na página do Livro
        function abrirAutorDaObra(e) {
            e.preventDefault();
            const autorNome = document.getElementById('boxNomeAutor').innerText;
            if (autorNome && autorNome !== "...") {
                localStorage.setItem('autorAtual', autorNome);
                window.location.href = '@Url.Action("Autor", "Biblioteca")';
            }
        }
    </script>
}
